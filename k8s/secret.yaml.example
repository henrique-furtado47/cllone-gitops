# MODELO — nunca comite o secret.yaml com valores reais.
# Crie um secret.yaml local (ignorado pelo .gitignore) e aplique manualmente:
#   kubectl apply -f k8s/secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: cllone-secrets
  namespace: cllone
type: Opaque
stringData:
  SECRET_KEY: "troque-esta-chave"
  POSTGRES_DB: cllone
  POSTGRES_USER: cllone
  POSTGRES_PASSWORD: "troque-esta-senha"
